{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "tsx watch src/main.ts",
    "start:inspect": "tsx watch --inspect=0.0.0.0 src/main.ts",
    "build": "run-s clean compile",
    "compile": "tsc",
    "clean": "rimraf build",
    "codegen": "graphql-codegen --config codegen.yml",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.1.2",
    "@graphql-tools/schema": "^10.0.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "firebase-admin": "^13.10.0",
    "fs-extra": "^10.1.0",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.6.1",
    "mongoose": "^8.24.0",
    "multer": "^2.1.1",
    "node-abort-controller": "^3.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.9.1",
    "sharp": "^0.34.5",
    "slug": "^11.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@graphql-codegen/add": "^7.0.1",
    "@graphql-codegen/cli": "7.1.2",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-mongodb": "4.0.2",
    "@graphql-codegen/typescript-resolvers": "6.0.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^9.0.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/sharp": "^0.30.5",
    "@types/slug": "^5.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "rimraf": "^3.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.50.0"
  }
