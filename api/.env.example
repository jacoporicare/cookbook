MONGO_URI=mongodb://localhost/cookbook
JWT_SECRET=your-secret-key-here
OPENAI_API_KEY=sk-your-openai-key-here
NEW_RECIPES_TOPIC=new_recipes.debug
APOLLO_EXPLORER_ENABLED=true

# Recipe images (S3-compatible object storage). Locally these point at the MinIO
# service from docker-compose so uploads never touch the production bucket. In
# production set S3_BUCKET/AWS_REGION for the real bucket, use the ambient AWS
# credentials, and leave S3_ENDPOINT / S3_FORCE_PATH_STYLE / S3_PUBLIC_BASE_URL
# unset.
S3_BUCKET=zradelnik-recipe-images
AWS_REGION=eu-central-1
S3_ENDPOINT=http://localhost:9100
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9100/zradelnik-recipe-images
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
